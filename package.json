{
  "name": "p-post-label-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"npm --workspace=@labelgen/web run dev\" \"npm --workspace=@labelgen/api run dev\"",
    "dev:web": "npm run preview --workspace=@labelgen/web",
    "dev:api": "npm --workspace=@labelgen/api run dev",
    "worker": "npm run worker --workspace=@labelgen/api",
    "worker:dev": "npm run worker:dev --workspace=@labelgen/api",
    "dev:all": "concurrently \"npm --workspace=@labelgen/api run dev\" \"npm --workspace=@labelgen/api run worker:dev\" \"npm --workspace=@labelgen/web run preview\"",
    "build:web": "npm run build --workspace=@labelgen/web",
    "start:web": "cd apps/web && npm run start",
    "start": "npm run start --workspace=@labelgen/api",
    "build": "npm run build --workspace=@labelgen/web && npm run build --workspace=@labelgen/api",
    "build:all": "npm run build",
    "lint": "npm run lint --workspace=@labelgen/web && npm run lint --workspace=@labelgen/api",
    "typecheck": "npm run typecheck --workspace=@labelgen/web && npm run typecheck --workspace=@labelgen/api",
    "test": "npm run smoke:railway --workspace=@labelgen/api",
    "preview": "npm run preview --workspace=@labelgen/web",
    "infra:check": "node scripts/infra-check.mjs",
    "infra:fix": "node scripts/infra-check.mjs --fix-redis",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:status": "docker compose ps",
    "infra:verify": "npm run infra:check && npm run prisma:generate --workspace=@labelgen/api",
    "s0:prereq": "node scripts/s0-prereq.mjs",
    "s0:bootstrap": "npm run infra:up && sleep 5 && npm run infra:fix && npm run prisma:generate --workspace=@labelgen/api && npm run prisma:migrate --workspace=@labelgen/api && npm run s0:prereq",
    "r2:verify": "node scripts/r2-verify.mjs",
    "r2:canary-check": "node scripts/r2-canary-check.mjs",
    "r2:rollback-check": "node scripts/r2-rollback-check.mjs",
    "r2:telemetry-summary": "node scripts/r2-telemetry-summary.mjs",
    "staging:env:check": "node scripts/staging-env-check.mjs",
    "staging:env:load": "echo 'PowerShell: . .\\scripts\\staging-env-load.ps1' && echo 'Bash/Zsh: source scripts/staging-env-load.sh (coming soon)' && node scripts/staging-env-check.mjs",
    "staging:r2:verify": "npm run staging:env:check && npm run r2:verify",
    "phase-3-verify": "tsx scripts/phase-3-verify.mjs",
    "strict-runtime-verify": "tsx scripts/strict-runtime-verify.mjs",
    "scope:check": "node scripts/verify-project-scope.mjs",
    "push:safe": "node scripts/safe-git-push.mjs",
    "railway:check": "node scripts/safe-railway-check.mjs",
    "r2:check": "node scripts/safe-r2-check.mjs",
    "auth:hammer": "tsx scripts/auth-hammer-test.mts",
    "auth:smoke:prod": "tsx scripts/production-auth-smoke.mts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@prisma/client": "^5.22.0",
    "firebase": "^12.12.1",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "puppeteer": "^22.15.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  }
}
