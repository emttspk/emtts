{
  "name": "p-post-label-generator",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "worker": "npm run worker -w apps/api",
    "dev:all": "concurrently \"npm run dev -w apps/api\" \"npm run worker -w apps/api\" \"npm run dev -w apps/web\"",
    "build:web": "npm run build -w apps/web",
    "start:web": "npm run preview -w apps/web",
    "start": "npm run start:web",
    "build": "npm run build --workspaces --if-present",
    "build:all": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  }
}
