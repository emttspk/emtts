{
  "name": "p-post-label-generator",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "worker": "npm run worker -w apps/api",
    "dev:all": "concurrently \"npm run dev -w apps/api\" \"npm run worker -w apps/api\" \"npm run dev -w apps/web\"",
    "build:web": "cd apps/web && npm install && npm run build",
    "start:web": "cd apps/web && npm run preview -- --host 0.0.0.0 --port $PORT",
    "start": "cd apps/api && npm run start",
    "build": "npm install && npm run build --workspace=@labelgen/api && npm run build --workspace=@labelgen/web",
    "build:all": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  }
}
