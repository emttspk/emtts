# ============================================================================
# LOCAL STAGING ENVIRONMENT TEMPLATE - COPY TO .env.staging.local FOR USE
# ============================================================================
# 
# IMPORTANT: NEVER COMMIT .env.staging.local — IT CONTAINS REAL SECRETS
# This file (.env.staging.local.example) is safe to commit; real values are local-only
#
# USAGE:
#   1. Copy this file: cp .env.staging.local.example .env.staging.local
#   2. Fill in real R2 credentials (see section below)
#   3. Load into shell: source .env.staging.local (bash/zsh) or ". .env.staging.local" (PowerShell)
#   4. Run staging tooling: npm run r2:verify, npm run r2:canary-check
#
# PRECEDENCE:
#   When npm/node scripts run, env is loaded in this order (first match wins):
#   1. Explicit shell vars (highest) — export VAR=value before running npm/node
#   2. .env.staging.local (if exists in current working directory)
#   3. .env in app-specific directory (tsx --env-file=.env)
#   4. Environment defaults in code (lowest)
#
# ============================================================================
# SECTION 1: REQUIRED R2 CREDENTIALS
# ============================================================================
# 
# Get these values from Cloudflare R2 console:
# - Account Settings → API Tokens → Create Token → S3-compatible
# - Download credentials to a safe location
# - Copy values here (NOT into git commits)
#
# R2_ENDPOINT format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=your-staging-bucket-name
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# Alternative key names (for compatibility, use either pair):
# R2_ACCESS_KEY=...
# R2_SECRET_KEY=...

# ============================================================================
# SECTION 2: STAGING MODE FLAGS - CONTROL S1 BEHAVIOR
# ============================================================================
#
# STAGING_R2_ENABLED: Master kill-switch for all S1 staging features
#   - Set to "true" to enable dual-write, uploads, canary checks
#   - Set to "false" or omit to run API/Worker in local-only mode (no R2)
#   - NOTE: Disabling this does NOT disable already-enabled features; you must rebuild
#
STAGING_R2_ENABLED=true

# ENABLE_DUAL_WRITE: Write artifacts to BOTH local storage AND R2
#   - Set to "true" only when STAGING_R2_ENABLED is "true"
#   - Requires R2_ENDPOINT, R2_BUCKET, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY
#
ENABLE_DUAL_WRITE=true

# ENABLE_R2_UPLOADS: Allow async uploads to R2 after local write succeeds
#   - Set to "true" only when ENABLE_DUAL_WRITE is "true"
#   - If false, dual-write is attempted but R2 uploads are disabled
#
ENABLE_R2_UPLOADS=true

# ENABLE_DUAL_READ: Read from R2 if local read fails (recovery fallback)
#   - Set to "false" for S1 staging (local-first is authoritative)
#   - Set to "true" only after S2 validation when dual-read is safe
#
ENABLE_DUAL_READ=false

# ============================================================================
# SECTION 3: CANARY MODE CONTROLS - LIMIT BLAST RADIUS DURING S1
# ============================================================================
#
# R2_CANARY_MODE: Control how many jobs dual-write during staged rollout
#   - "disabled" (default): ALL jobs dual-write if ENABLE_DUAL_WRITE=true
#   - "job-percentage": Only X% of jobs (see R2_CANARY_PERCENTAGE)
#   - "job-count": Only first X jobs (see R2_CANARY_MAX_JOBS)
#
R2_CANARY_MODE=job-percentage

# R2_CANARY_PERCENTAGE: When R2_CANARY_MODE=job-percentage, what % dual-write
#   - Valid range: 1-100
#   - Example: 5 means 5% of jobs dual-write to R2
#   - Recommended starting value: 5 or 10
#
R2_CANARY_PERCENTAGE=5

# R2_CANARY_MAX_JOBS: When R2_CANARY_MODE=job-count, how many jobs max
#   - Valid range: 1-999999
#   - Example: 100 means only the first 100 jobs dual-write
#   - Recommended starting value: 100
#
R2_CANARY_MAX_JOBS=100

# ============================================================================
# SECTION 4: R2 OPERATION TUNING (OPTIONAL)
# ============================================================================
#
# R2_MAX_CONCURRENT_STREAMS: Number of simultaneous uploads to R2
#   - Default: 5
#   - Increase for higher throughput, decrease for stability
#
R2_MAX_CONCURRENT_STREAMS=5

# R2_TIMEOUT_MS: Timeout for individual R2 operations (milliseconds)
#   - Default: 30000 (30 seconds)
#   - Increase if uploads frequently timeout
#
R2_TIMEOUT_MS=30000

# R2_RETRY_LIMIT: Number of retries for failed R2 uploads
#   - Default: 3
#   - Increase for reliability, decrease for speed
#
R2_RETRY_LIMIT=3

# ============================================================================
# SECTION 5: TELEMETRY & DEBUGGING (OPTIONAL)
# ============================================================================
#
# TELEMETRY_LOG_FILE: Path to write staged telemetry events
#   - If set, JSON telemetry is appended to this file
#   - If not set, telemetry only goes to console.log
#   - Useful for auditing staging behavior and debugging issues
#
TELEMETRY_LOG_FILE=./telemetry-staging.log

# ============================================================================
# SECTION 6: STORAGE PROVIDER & PATHS (USUALLY NOT CHANGED FOR LOCAL)
# ============================================================================
#
# STORAGE_PROVIDER: Which storage backend to use
#   - "local": Write to disk (default, local-first architecture)
#   - "r2": Write to R2 only (NOT RECOMMENDED for S1 staging)
#
STORAGE_PROVIDER=local

# STORAGE_DIR: Where local artifacts are written
#   - Default: "storage" (relative to working directory)
#
STORAGE_DIR=storage

# ============================================================================
# END OF STAGING ENV TEMPLATE
# ============================================================================
