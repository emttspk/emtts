{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=optional --build-from-source && npm rebuild canvas --build-from-source && npm run build"
  },
  "deploy": {
    "releaseCommand": "npx prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "startCommand": "node apps/api/dist/index.js"
  },
  "services": {
    "worker": {
      "deploy": {
        "startCommand": "node apps/api/dist/worker.js"
      }
    }
  }
}