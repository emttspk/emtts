generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  username        String?
  passwordHash    String
  role            String   @default("USER")
  suspended       Boolean  @default(false)
  onboardingComplete Boolean @default(true)
  createdAt       DateTime @default(now())
  companyName     String?
  address         String?
  contactNumber   String?  @unique
  cnic            String?  @unique
  originCity      String?
  extraLabelCredits    Int      @default(0)
  extraTrackingCredits Int      @default(0)

  subscriptions Subscription[]
  jobs          LabelJob[]
  trackingJobs  TrackingJob[]
  shipments     Shipment[]
  usage         UsageMonthly[]
  refunds       RefundRequest[]
  complaintQueue ComplaintQueue[]
  payments      Payment[]
  invoices      Invoice[]
}

model Plan {
  id                String   @id @default(uuid())
  name              String
  priceCents        Int
  monthlyLabelLimit Int
  monthlyTrackingLimit Int    @default(0)
  createdAt         DateTime @default(now())

  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  planId             String
  status             String             @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]
  invoices Invoice[]

  @@index([userId])
  @@index([planId])
}

model Payment {
  id                   String        @id @default(uuid())
  userId               String
  planId               String
  subscriptionId       String?
  provider             String        @default("EP_GATEWAY")
  reference            String        @unique
  gatewayOrderId       String        @unique
  gatewayTransactionId String?
  idempotencyKey       String        @unique
  checkoutToken        String        @unique
  kind                 String        @default("PURCHASE")
  status               String        @default("PENDING")
  amountCents          Int
  currency             String        @default("PKR")
  verifiedAt           DateTime?
  paidAt               DateTime?
  failureReason        String?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?
  events       PaymentEvent[]

  @@index([userId, status])
  @@index([planId])
  @@index([subscriptionId])
}

model Invoice {
  id             String        @id @default(uuid())
  userId         String
  planId         String
  paymentId      String        @unique
  subscriptionId String?
  invoiceNumber  String        @unique
  amountCents    Int
  currency       String        @default("PKR")
  status         String        @default("OPEN")
  issuedAt       DateTime      @default(now())
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  payment      Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([planId])
  @@index([subscriptionId])
}

model PaymentEvent {
  id          String   @id @default(uuid())
  paymentId   String
  eventId     String   @unique
  source      String
  status      String
  payloadHash String
  signature   String?
  payloadJson Json
  createdAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, source, payloadHash])
  @@index([paymentId, source])
}

model UsageMonthly {
  id              String   @id @default(uuid())
  userId          String
  month           String
  labelsGenerated Int      @default(0)
  labelsQueued    Int      @default(0)
  trackingGenerated Int    @default(0)
  trackingQueued    Int    @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([month])
}

model LabelJob {
  id                String    @id @default(uuid())
  userId            String
  originalFilename  String
  recordCount       Int
  unitCount         Int       @default(0)
  includeMoneyOrders Boolean  @default(true)
  status            String    @default("QUEUED")
  error             String?
  uploadPath        String
  labelsPdfPath     String?
  moneyOrderPdfPath String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Shipment {
  id              String   @id @default(uuid())
  userId          String
  trackingNumber  String
  mosId           String?
  articleType     String?
  bookingOffice   String?
  deliveryOffice  String?
  consigneeName   String?
  consigneeAddress String?
  consigneePhone  String?
  lastScanDate    DateTime?
  currentStatus   String?
  returnReason    String?
  complaintEligible Boolean @default(false)
  complaintDate   DateTime?
  events          String?
  shipmentType    String?
  status          String?
  city            String?
  latestDate      String?
  latestTime      String?
  daysPassed      Int?
  complaintStatus String?  @default("NOT_REQUIRED")
  complaintText   String?
  rawJson         String?
  adminCode       String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([complaintStatus])
  @@unique([userId, trackingNumber])
  @@index([userId])
}

model TrackingJob {
  id               String   @id @default(uuid())
  userId           String
  kind             String   @default("BULK_TRACK") // BULK_TRACK | COMPLAINT
  status           String   @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  error            String?
  originalFilename String?
  recordCount      Int      @default(0)
  uploadPath       String?
  resultPath       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([kind])
}

model RefundRequest {
  id          String   @id @default(uuid())
  userId      String
  trackingId  String?
  units       Int
  reason      String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ComplaintQueue {
  id                 String   @id @default(uuid())
  userId             String
  trackingId         String
  payloadJson        Json
  complaintStatus    String   @default("queued")
  complaintId        String?
  dueDate            DateTime?
  retryCount         Int      @default(0)
  nextRetryAt        DateTime?
  lastError          String?
  browserSessionJson Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trackingId])
  @@index([complaintStatus])
  @@index([nextRetryAt])
}

model MoneyOrderTemplate {
  id            String                    @id @default(uuid())
  name          String
  backgroundUrl String?
  version       Int                       @default(1)
  isActive      Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  fields        MoneyOrderTemplateField[]

  @@index([isActive])
}

model MoneyOrderTemplateField {
  id         String             @id @default(uuid())
  templateId String
  fieldKey   String
  fieldType  String
  x          Float
  y          Float
  width      Float
  height     Float
  fontSize   Int                @default(12)
  fontFamily String             @default("Arial")
  fontWeight String             @default("normal")
  fontStyle  String             @default("normal")
  textColor  String             @default("#0f172a")
  textAlign  String             @default("left")
  rotation   Float              @default(0)
  isLocked   Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  template   MoneyOrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([fieldKey])
}

model MoneyOrder {
  seq              BigInt    @id @default(autoincrement())
  id               String
  userId           String
  trackingNumber   String
  mosNumber        String    @unique
  segmentIndex     Int       @default(0)
  trackingId       String?
  issueDate        String?
  amount           Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, trackingNumber, segmentIndex])
  @@index([userId])
  @@index([trackingNumber])
  @@index([trackingId])
  @@index([issueDate])
}
