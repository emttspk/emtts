generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  username        String?
  passwordHash    String
  role            String   @default("USER")
  suspended       Boolean  @default(false)
  onboardingComplete Boolean @default(true)
  createdAt       DateTime @default(now())
  companyName     String?
  address         String?
  contactNumber   String?  @unique
  cnic            String?  @unique
  originCity      String?
  extraLabelCredits    Int      @default(0)
  extraTrackingCredits Int      @default(0)

  subscriptions Subscription[]
  jobs          LabelJob[]
  trackingJobs  TrackingJob[]
  shipments     Shipment[]
  usage         UsageMonthly[]
  refunds       RefundRequest[]
  complaintQueue ComplaintQueue[]
  payments      Payment[]
  invoices      Invoice[]
  manualPayments ManualPaymentRequest[]
  accountRiskSignals AccountRiskSignal[]
  supportTickets SupportTicket[]
  supportTicketMessages SupportTicketMessage[]
  supportTicketAttachments SupportTicketAttachment[]
  analyticsEvents AnalyticsEvent[]
  supportTicketAuditLogs SupportTicketAuditLog[]
  supportNotifications SupportTicketNotification[]
  complaintNotifications ComplaintNotification[]
  aggregatorQuotes AggregatorQuote[]
  aggregatorBookings AggregatorBooking[]
  aggregatorPaymentTransactions AggregatorPaymentTransaction[]
  authRefreshTokens AuthRefreshToken[]
}

model AuthRefreshToken {
  id             String   @id
  userId         String
  role           String
  tokenHash      String   @unique
  replacedByHash String?
  revokedAt      DateTime?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Plan {
  id                String   @id @default(uuid())
  name              String
  priceCents        Int
  monthlyLabelLimit Int
  monthlyTrackingLimit Int    @default(0)
  createdAt         DateTime @default(now())

  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]
  manualPayments ManualPaymentRequest[]
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  planId             String
  status             String             @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]
  invoices Invoice[]

  @@index([userId])
  @@index([planId])
}

model Payment {
  id                   String        @id @default(uuid())
  userId               String
  planId               String
  subscriptionId       String?
  provider             String        @default("EP_GATEWAY")
  reference            String        @unique
  txnRefNo             String?
  gatewayOrderId       String        @unique
  gatewayTransactionId String?
  providerTxnId        String?
  idempotencyKey       String        @unique
  checkoutToken        String        @unique
  kind                 String        @default("PURCHASE")
  status               String        @default("PENDING")
  amountCents          Int
  currency             String        @default("PKR")
  responseCode         String?
  responseMessage      String?
  rawRequest           Json?
  rawResponse          Json?
  hashVerified         Boolean       @default(false)
  verifiedAt           DateTime?
  paidAt               DateTime?
  failureReason        String?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?
  events       PaymentEvent[]

  @@index([userId, status])
  @@index([planId])
  @@index([subscriptionId])
  @@index([txnRefNo])
}

model Invoice {
  id             String        @id @default(uuid())
  userId         String
  planId         String
  paymentId      String        @unique
  subscriptionId String?
  invoiceNumber  String        @unique
  amountCents    Int
  currency       String        @default("PKR")
  status         String        @default("OPEN")
  issuedAt       DateTime      @default(now())
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  payment      Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  manualPayments ManualPaymentRequest[]

  @@index([userId, status])
  @@index([planId])
  @@index([subscriptionId])
}

model PaymentEvent {
  id          String   @id @default(uuid())
  paymentId   String
  eventId     String   @unique
  source      String
  status      String
  payloadHash String
  signature   String?
  payloadJson Json
  createdAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, source, payloadHash])
  @@index([paymentId, source])
}

model AnalyticsEvent {
  id            String   @id @default(uuid())
  sessionId     String
  userId        String?
  eventName     String
  path          String?
  landingPath   String?
  source        String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  referrer      String?
  planName      String?
  method        String?
  status        String?
  feature       String?
  amountCents   Int?
  valueCents    Int?
  count         Int?
  currency      String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([sessionId, createdAt])
  @@index([utmSource, utmCampaign])
  @@index([landingPath])
  @@index([userId, eventName])
}

model UsageMonthly {
  id              String   @id @default(uuid())
  userId          String
  month           String
  labelsGenerated Int      @default(0)
  labelsQueued    Int      @default(0)
  trackingGenerated Int    @default(0)
  trackingQueued    Int    @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([month])
}

model LabelJob {
  id                String    @id @default(uuid())
  userId            String
  originalFilename  String
  recordCount       Int
  unitCount         Int       @default(0)
  includeMoneyOrders Boolean  @default(true)
  status            String    @default("QUEUED")
  error             String?
  uploadPath        String
  labelsPdfPath     String?
  labelsPdfSyncedAt DateTime?  // R2 sync timestamp for label PDF (null = not synced yet)
  moneyOrderPdfPath String?
  moneyOrderPdfSyncedAt DateTime?  // R2 sync timestamp for money order PDF (null = not synced yet)
  trackingMasterPath String?
  trackingMasterSyncedAt DateTime?  // R2 sync timestamp for tracking master XLSX (null = not synced yet)
  // Phase B: Upload source file R2 durability fields (additive only)
  uploadObjectKey   String?   // R2 object key for source CSV/XLSX file
  uploadBucket      String?   // R2 bucket name at time of upload
  uploadSyncedAt    DateTime? // When R2 backup of source file succeeded
  uploadSyncStatus  String?   // NOT_ATTEMPTED | PENDING | R2_SYNCED | FAILED
  uploadSizeBytes   Int?      // Byte size of uploaded source file
  uploadOriginalExt String?   // File extension of source file (.csv or .xlsx)
  // Phase C: Local upload cleanup lifecycle metadata
  uploadLocalCleanupStatus      String?   // PENDING | COMPLETED | RETRY_PENDING | FAILED_TERMINAL | SKIPPED_UNSAFE_PATH | SKIPPED_MISSING_FILE
  uploadLocalCleanupAttempts    Int       @default(0)
  uploadLocalCleanupLastError   String?
  uploadLocalCleanupNextRetryAt DateTime?
  uploadLocalDeletedAt          DateTime?
  deleteAfterAt      DateTime?
  retentionTierSnapshot String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([labelsPdfSyncedAt])
  @@index([moneyOrderPdfSyncedAt])
  @@index([trackingMasterSyncedAt])
  @@index([deleteAfterAt])
  @@index([uploadSyncStatus, uploadSyncedAt])
  @@index([uploadLocalCleanupStatus, uploadLocalCleanupNextRetryAt])
  @@index([uploadLocalDeletedAt])
}

model Shipment {
  id              String   @id @default(uuid())
  userId          String
  trackingNumber  String
  mosId           String?
  articleType     String?
  bookingOffice   String?
  deliveryOffice  String?
  consigneeName   String?
  consigneeAddress String?
  consigneePhone  String?
  lastScanDate    DateTime?
  currentStatus   String?
  returnReason    String?
  complaintEligible Boolean @default(false)
  complaintDate   DateTime?
  events          String?
  shipmentType    String?
  status          String?
  city            String?
  latestDate      String?
  latestTime      String?
  daysPassed      Int?
  complaintStatus String?  @default("NOT_REQUIRED")
  complaintText   String?
  rawJson         String?
  adminCode       String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([complaintStatus])
  @@unique([userId, trackingNumber])
  @@index([userId])
}

model TrackingJob {
  id               String   @id @default(uuid())
  userId           String
  kind             String   @default("BULK_TRACK") // BULK_TRACK | COMPLAINT
  status           String   @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  error            String?
  originalFilename String?
  recordCount      Int      @default(0)
  uploadPath       String?
  resultPath       String?
  resultSyncedAt   DateTime?  // R2 sync timestamp for tracking result JSON (null = not synced yet)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([kind])
  @@index([resultSyncedAt])
}

model RefundRequest {
  id          String   @id @default(uuid())
  userId      String
  trackingId  String?
  units       Int
  reason      String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ComplaintQueue {
  id                 String   @id @default(uuid())
  userId             String
  trackingId         String
  payloadJson        Json
  complaintStatus    String   @default("queued")
  complaintId        String?
  dueDate            DateTime?
  retryCount         Int      @default(0)
  nextRetryAt        DateTime?
  lastError          String?
  browserSessionJson Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trackingId])
  @@index([complaintStatus])
  @@index([nextRetryAt])
}

model MoneyOrderTemplate {
  id            String                    @id @default(uuid())
  name          String
  backgroundUrl String?
  version       Int                       @default(1)
  isActive      Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  fields        MoneyOrderTemplateField[]

  @@index([isActive])
}

model MoneyOrderTemplateField {
  id         String             @id @default(uuid())
  templateId String
  fieldKey   String
  fieldType  String
  x          Float
  y          Float
  width      Float
  height     Float
  fontSize   Int                @default(12)
  fontFamily String             @default("Arial")
  fontWeight String             @default("normal")
  fontStyle  String             @default("normal")
  textColor  String             @default("#0f172a")
  textAlign  String             @default("left")
  rotation   Float              @default(0)
  isLocked   Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  template   MoneyOrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([fieldKey])
}

model MoneyOrder {
  seq              BigInt    @id @default(autoincrement())
  id               String
  userId           String
  trackingNumber   String
  mosNumber        String    @unique
  segmentIndex     Int       @default(0)
  trackingId       String?
  issueDate        String?
  amount           Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, trackingNumber, segmentIndex])
  @@index([userId])
  @@index([trackingNumber])
  @@index([trackingId])
  @@index([issueDate])
}

model TrackingIdSequence {
  prefix       String
  dateCode     String   @map("date_code")
  nextSequence Int      @default(1) @map("next_sequence")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@id([prefix, dateCode])
  @@map("tracking_id_sequences")
}

model ManualPaymentRequest {
  id            String    @id @default(uuid())
  userId        String
  planId        String
  invoiceId     String?   // links to Invoice created during plan selection
  paymentMethod String    // JAZZCASH | EASYPAISA | BANK_TRANSFER
  transactionId String
  screenshotPath String?
  amountCents   Int
  currency      String    @default("PKR")
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  notes         String?
  verifiedBy    String?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([planId])
  @@index([invoiceId])
  @@index([status])
}

model BillingSettings {
  id               Int      @id @default(1)
  jazzcashNumber   String
  jazzcashTitle    String
  jazzcashQrPath   String?
  easypaisaNumber  String
  easypaisaTitle   String
  easypaisaQrPath  String?
  bankName         String?
  bankTitle        String?
  bankAccountNumber String?
  bankIban         String?
  bankQrPath       String?
  standardPrice    Int
  businessPrice    Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AccountRiskSignal {
  id           String   @id @default(uuid())
  userId       String?
  signalType   String
  signalHash   String
  source       String
  planTier     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([signalType, signalHash])
  @@index([planTier])
  @@index([createdAt])
}

model SupportTicket {
  id                 String   @id @default(uuid())
  ticketNumber       String   @unique
  userId             String
  subject            String
  category           String
  priority           String   @default("MEDIUM")
  status             String   @default("OPEN")
  initialMessage     String
  firstResponseDueAt DateTime?
  lastReplyAt        DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  isPreserved        Boolean  @default(false)
  deleteAfter        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    SupportTicketMessage[]
  attachments SupportTicketAttachment[]
  auditLogs   SupportTicketAuditLog[]
  notifications SupportTicketNotification[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([updatedAt])
  @@index([firstResponseDueAt])
  @@index([isPreserved])
  @@index([deleteAfter])
}

model SupportTicketMessage {
  id             String   @id @default(uuid())
  ticketId       String
  authorUserId   String
  authorRole     String
  message        String
  isInternalNote Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ticket      SupportTicket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser  User                      @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  attachments SupportTicketAttachment[]

  @@index([ticketId])
  @@index([authorUserId])
  @@index([createdAt])
}

model SupportTicketAttachment {
  id               String   @id @default(uuid())
  ticketId         String
  messageId        String
  uploadedByUserId String
  objectKey        String
  originalName     String
  safeFileName     String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())

  ticket         SupportTicket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message        SupportTicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedByUser User                 @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([messageId])
  @@index([uploadedByUserId])
  @@index([createdAt])
}

model SupportTicketAuditLog {
  id          String   @id @default(uuid())
  ticketId    String
  actorUserId String
  actorRole   String
  action      String
  fromValue   String?
  toValue     String?
  metadataJson Json?
  createdAt   DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUser User          @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model SupportTicketNotification {
  id        String   @id @default(uuid())
  userId    String?
  ticketId  String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([ticketId])
  @@index([type])
  @@index([createdAt])
}

model ComplaintNotification {
  id          String   @id @default(uuid())
  userId      String
  trackingId  String
  type        String   @default("complaint_status_change")
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([trackingId])
  @@index([type])
  @@index([createdAt])
}

model AggregatorQuote {
  id                    String   @id @default(uuid())
  userId                String
  quoteVersion          String
  quoteInputJson        Json
  quoteResultJson       Json
  rateCardVersionSetJson Json
  sourceFileKey         String?
  sourceObjectKey       String?
  sourceBucket          String?
  sourceSizeBytes       Int?
  sourceContentType     String?
  sourceChecksum        String?
  sourceOriginalFilename String?
  sourceUploadedAt      DateTime?
  expiresAt             DateTime?
  createdAt             DateTime @default(now())

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings AggregatorBooking[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model AggregatorBooking {
  id                         String   @id @default(uuid())
  bookingNo                  String   @unique
  userId                     String
  aggregatorQuoteId          String
  quoteSnapshotJson          Json
  status                     String
  intakeMethod               String
  hubCity                    String
  senderName                 String
  senderPhone                String
  senderAddress              String
  senderCity                 String
  specialInstructions        String?
  totalArticles              Int
  totalActualWeightGrams     Int
  totalChargeableWeightGrams Int
  totalBasePostage           Int
  totalRegistrationFee       Int
  totalValuePayableFee       Int
  totalInsuranceFee          Int
  totalOfficialPostalCharge  Int
  paymentStatus              String
  adminReviewStatus          String
  adminNotes                 String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  submittedAt                DateTime?
  reviewedAt                 DateTime?
  reviewedByUserId           String?

  user               User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote              AggregatorQuote                @relation(fields: [aggregatorQuoteId], references: [id], onDelete: Restrict)
  items              AggregatorBookingItem[]
  statusEvents       AggregatorBookingStatusEvent[]
  auditLogs          AggregatorBookingAuditLog[]
  documents          AggregatorBookingDocument[]
  paymentPlaceholder AggregatorPaymentPlaceholder?
  paymentTransactions AggregatorPaymentTransaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([adminReviewStatus, createdAt])
  @@index([intakeMethod])
  @@index([hubCity])
}

model AggregatorBookingItem {
  id                         String   @id @default(uuid())
  bookingId                  String
  rowNo                      Int
  receiverName               String?
  receiverPhone              String?
  receiverAddress            String?
  receiverCity               String?
  serviceCode                String
  articleCategory            String
  weightGrams                Int?
  chargeableWeightGrams      Int?
  basePostage                Int
  registrationFee            Int
  valuePayableFee            Int
  insuranceFee               Int
  totalOfficialPostalCharge  Int
  missingComponentsJson      Json
  warningsJson               Json
  errorsJson                 Json
  futurePakistanPostTrackingNo String?

  booking AggregatorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, rowNo])
}

model AggregatorBookingStatusEvent {
  id          String   @id @default(uuid())
  bookingId   String
  fromStatus  String?
  toStatus    String
  actorType   String
  actorUserId String
  reasonCode  String?
  note        String?
  createdAt   DateTime @default(now())

  booking AggregatorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([toStatus, createdAt])
}

model AggregatorBookingAuditLog {
  id          String   @id @default(uuid())
  bookingId   String
  action      String
  actorType   String
  actorUserId String
  targetField String?
  oldValueJson Json?
  newValueJson Json?
  ipHash      String?
  userAgentHash String?
  createdAt   DateTime @default(now())

  booking AggregatorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([action, createdAt])
}

model AggregatorBookingDocument {
  id               String   @id @default(uuid())
  bookingId        String
  docType          String
  storageKey       String
  bucket           String?
  objectKey        String?
  sizeBytes        Int?
  contentType      String?
  checksum         String?
  uploadStatus     String   @default("PENDING")
  localTempPath    String?
  localCleanupStatus String @default("NOT_REQUIRED")
  localCleanupAttempts Int  @default(0)
  localCleanupLastError String?
  localCleanupNextRetryAt DateTime?
  originalFileName String
  mimeType         String
  uploadedByUserId String
  createdAt        DateTime @default(now())

  booking AggregatorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([uploadStatus, createdAt])
  @@index([localCleanupStatus, localCleanupNextRetryAt])
}

model AggregatorPaymentPlaceholder {
  id                   String   @id @default(uuid())
  bookingId            String   @unique
  paymentStatus        String
  placeholderMethod    String?
  placeholderReference String?
  placeholderAmount    Int?
  placeholderCurrency  String?
  dueAt                DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  booking AggregatorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([paymentStatus, createdAt])
}

model AggregatorPaymentTransaction {
  id                 String   @id @default(uuid())
  bookingId          String
  userId             String
  provider           String
  method             String
  amount             Int
  currency           String   @default("PKR")
  orderRef           String   @unique
  gatewayTxnRef      String?
  status             String
  requestPayloadJson Json?
  callbackPayloadJson Json?
  statusInquiryJson  Json?
  secureHashVerified Boolean  @default(false)
  idempotencyKey     String   @unique
  callbackHash       String?
  failureReason      String?
  reconciliationNote String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  booking AggregatorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
  @@index([gatewayTxnRef])
  @@index([callbackHash])
  @@index([createdAt])
}
