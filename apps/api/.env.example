NODE_ENV=development
PORT=4000
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://labelgen:labelgen@localhost:5432/labelgen?schema=public
REDIS_URL=redis://default:PASSWORD@HOST:PORT
JWT_SECRET=change-me-change-me-change-me
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3000
STORAGE_DIR=storage
PYTHON_SERVICE_URL=http://localhost:8000
ADMIN_BOOTSTRAP_SECRET=change-me-bootstrap-secret
MONEY_ORDER_FRONT_IMAGE_PATH=
MONEY_ORDER_BACK_IMAGE_PATH=
ENABLE_TEMPLATE_DESIGNER=false
FRONTEND_URL=https://www.epost.pk
EP_GATEWAY_SECRET=
EP_GATEWAY_INITIATE_URL=
EP_GATEWAY_INQUIRY_URL=
EP_GATEWAY_MERCHANT_ID=
EP_GATEWAY_STORE_ID=
EP_GATEWAY_USERNAME=
EP_GATEWAY_PASSWORD=
EP_GATEWAY_REQUEST_TIMEOUT_MS=15000
EP_GATEWAY_INITIATE_CONTENT_TYPE=application/json
EP_GATEWAY_SIGNATURE_METHOD=hmac
EP_GATEWAY_SIGNATURE_ALGO=sha256
EP_GATEWAY_SIGNATURE_FORMAT=values
EP_GATEWAY_SIGNATURE_FIELDS=reference,status,transactionId,amountCents,timestamp
EP_GATEWAY_STATUS_SUCCESS_VALUES=SUCCESS,SUCCEEDED,PAID,00,000
EP_GATEWAY_STATUS_FAILED_VALUES=FAILED,FAIL,ERROR,01,999
EP_GATEWAY_STATUS_CANCELED_VALUES=CANCELED,CANCELLED,CANCEL
EP_GATEWAY_PAYMENT_MODE=CC
# JazzCash backend API service only. Never place real JazzCash credentials in frontend code, GitHub, docs, or web-service variables.
JAZZCASH_ENV=sandbox
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=https://api.epost.pk/api/payments/jazzcash/callback
JAZZCASH_SANDBOX_ENDPOINT=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/
JAZZCASH_LIVE_ENDPOINT=https://payments.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/
JAZZCASH_MOBILE_WALLET_ENDPOINT_SANDBOX=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/Payment/DoTransaction
JAZZCASH_MOBILE_WALLET_ENDPOINT_LIVE=https://payments.jazzcash.com.pk/ApplicationAPI/API/Payment/DoTransaction
JAZZCASH_MOBILE_WALLET_ENABLED=true
JAZZCASH_MOBILE_WALLET_CNIC=345678
JAZZCASH_ALLOWED_ORIGINS=https://sandbox.jazzcash.com.pk,https://payments.jazzcash.com.pk
JAZZCASH_TXN_TYPE=MWALLET
JAZZCASH_BANK_ID=TBANK
JAZZCASH_PRODUCT_ID=RETL
JAZZCASH_SUBMERCHANT_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
