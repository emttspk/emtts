{
  "name": "@labelgen/api",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --ignore storage/** --ignore apps/api/storage/** --env-file=.env src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "postinstall": "prisma generate",
    "prestart": "npm run build",
    "worker": "tsx --env-file=.env src/worker.ts",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.5",
    "bwip-js": "^4.7.0",
    "canvas": "^3.2.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.6.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "puppeteer": "^24.39.1",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3"
  }
}
