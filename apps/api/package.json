{
  "name": "@labelgen/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --ignore storage/** --ignore apps/api/storage/** --env-file=.env src/index.ts",
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const path=require('path');const roots=['dist',path.join('apps','api','dist')];for(const out of roots){const srcDir=path.join(out,'src');if(!fs.existsSync(srcDir)) continue;for(const name of ['index.js','worker.js']){const from=path.join(srcDir,name);const to=path.join(out,name);if(fs.existsSync(from)){fs.copyFileSync(from,to);}}}\"",
    "worker:dev": "tsx --env-file=.env src/worker.ts",
    "worker": "node dist/worker.js",
    "start": "node dist/index.js",
    "smoke:railway": "node scripts/railway-smoke-test.mjs",
    "debug:auto": "tsx --env-file=.env scripts/autoDebug.ts",
    "prisma:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "bwip-js": "^4.7.0",
    "canvas": "^3.2.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.22.0",
    "puppeteer": "^22.15.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.37",
    "ts-node": "^10.9.2"
  }
}
